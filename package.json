{
  "name": "hlid",
  "description": "Hliðskjálf - Watcher of Worlds",
  "version": "0.0.57",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:all": "concurrently -n ui,server -c cyan,magenta 'bun --bun run dev' 'bun run dev:server'",
    "build": "vite build && bun scripts/embed-client.ts",
    "build:win": "bun run build && bun scripts/build-win.ts",
    "postinstall": "bun scripts/embed-client.ts",
    "start": "bun src/server/index.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:db": "bun test src/db/",
    "test:all": "vitest run && bun test src/db/",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "stage": "biome format --write && biome lint --fix && biome check --fix",
    "version:bump": "bumpp --quiet",
    "generate-icons": "bun scripts/generate-icons.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.167.35",
    "bumpp": "^11.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-mark-highlight": "^0.1.1",
    "remark-math": "^6.0.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-win32-x64": "^0.2.138"
  }
}
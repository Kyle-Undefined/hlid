{
	"$schema": "./node_modules/fallow/schema.json",
	"entry": [
		"src/server/index.ts",
		"src/start.ts",
		"public/sw.js",
		"bump.config.ts",
		"scripts/*.ts"
	],
	"dynamicallyLoaded": [
		"src/server/pty-worker.cjs",
		"src/server/fixtures/fake-acp-agent.mjs"
	],
	"ignoreDependencies": [
		"@anthropic-ai/claude-agent-sdk-win32-x64",
		"png-to-ico",
		"istanbul-lib-coverage",
		"istanbul-lib-report",
		"istanbul-reports"
	],
	"ignoreUnresolvedImports": ["../../dist/server/server.js"],
	"ignoreExports": [
		{
			"file": "src/hooks/wsStore.ts",
			"exports": ["EMPTY_STATS"]
		},
		{
			"file": "src/lib/codexPath.ts",
			"exports": ["__resetCacheForTesting"]
		},
		{
			"file": "src/lib/install.ts",
			"exports": ["maybeSelfInstall"]
		},
		{
			"file": "src/db/activity.ts",
			"exports": ["DURATION_BUCKETS_MS"]
		},
		{
			"file": "src/db/schema.ts",
			"exports": ["setDbForTest"]
		},
		{
			"file": "src/db/sessions.ts",
			"exports": ["setSessionClaudeId"]
		},
		{
			"file": "src/hooks/updateStore.ts",
			"exports": ["setUpdateStatus"]
		},
		{
			"file": "src/hooks/wsStore.ts",
			"exports": ["subscribeToSession", "getSubscribedSessionId"]
		},
		{
			"file": "src/lib/updates.ts",
			"exports": ["cleanupStagingDir"]
		},
		{
			"file": "src/lib/usageWindows.ts",
			"exports": ["applyRateLimitToWindowData", "mergeUsageWindows"]
		},
		{
			"file": "src/lib/vault.ts",
			"exports": ["scanFolderGroups"]
		},
		{
			"file": "src/server/codexAppServer.ts",
			"exports": ["__resetCodexAppServersForTesting"]
		},
		{
			"file": "src/server/runState.ts",
			"exports": ["getRunBuffer"]
		},
		{
			"file": "src/db/index.ts",
			"exports": ["UsageWindow"]
		},
		{
			"file": "src/server/usageGate.ts",
			"exports": ["_resetForTests"]
		}
	],
	"rules": {
		"duplicate-exports": "off"
	},
	"ignoreExportsUsedInFile": true,
	"health": {
		"coverage": "coverage/coverage-final.json",
		"ignore": [
			"scripts/**",
			"src/server/fixtures/**",
			"public/sw.js",
			"src/hooks/wsStore.test-utils.ts",
			"src/lib/claudePath.ts",
			"src/components/wizard/FolderBrowser.tsx",
			"src/lib/providerOptions.ts",
			"src/lib/originGate.ts",
			"src/lib/utils.ts"
		]
	},
	"duplicates": {
		"ignore": ["src/db/schema.ts"]
	},
	"production": true,
	"usedClassMembers": [
		{
			"implements": "AgentProvider",
			"members": [
				"label",
				"effortLevels",
				"permissionModes",
				"usageWindows",
				"check"
			]
		},
		"attachThread",
		"detachThread",
		"setSessionLabel",
		"probeMcpStatus",
		"handlePlanModeExitResponse",
		"getPendingPlanModeExits",
		"getQueueState"
		,"proxyConfig"
		,"write"
		,"resize"
		,"kill"
		,"addSubscriber"
		,"removeSubscriber"
		,"getSubscriberCount"
		,"broadcast"
		,"send"
		,"getReplayBuffer"
		,"clearError"
		,"reinitialize"
		,"syncConfig"
		,"setModel"
		,"setPermissionMode"
		,"getAccountInfo"
		,"getLastMcpStatus"
		,"restoreMcpStatus"
		,"probeSlashCommands"
		,"isRunning"
		,"handlePermissionResponse"
		,"getPendingAskUserQuestions"
		,"handleAskUserQuestionResponse"
		,"clearHistory"
		,"runQuery"
		,"cancelQueued"
		,"promoteQueued"
		,"getSessionsStatus"
		,"getSize"
		,"findByDbSessionId"
		,"skipSleep"
		,"getSleepState"
	],
	"ignorePatterns": [
		"src/hooks/wsStore.test-utils.ts",
		"src/routeTree.gen.ts",
		"src/server/embedded-client.ts",
		"src/server/pty-embed-assets/**",
		"src/server/whisper-embed-assets/**",
		"src/server/codexProtocol/**",
		"dist/**",
		"build/**",
		"coverage/**"
	]
}
